# Server
PORT=50001
MODE=pro

# Database
DB_LOCAL_URL=mongodb://localhost:27017/ecommerce
DB_PRO_URL=mongodb+srv://<user>:<password>@<cluster>/<db>

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SECRET=replace-with-long-random-hex

# Cloudinary
cloud_name=
api_key=
api_secret=

# Frontend URLs (used for Paynow redirects, CORS, etc.)
client_customer_production_url=https://www.nimbo.co.zw/
client_admin_production_url=https://nimbo-dashboard.vercel.app/

# Paynow
PAYNOW_INTEGRATION_ID=
PAYNOW_INTEGRATION_KEY=
PAYNOW_RESULT_URL=https://nimbo-backend.onrender.com/api/order/paynow/result
PAYNOW_RETURN_URL=https://www.nimbo.co.zw/order/confirm
